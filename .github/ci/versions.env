# CI agent image pinned versions.
# Single source of truth for `.github/ci/Dockerfile` build args.
#
# `.github/workflows/ci-image.yml` loads this file into $GITHUB_ENV. That loader strips
# comments and blank lines, because $GITHUB_ENV rejects them.
CLAUDE_CODE_VERSION=2.1.167
CODEX_CLI_VERSION=0.137.0
ACTIONLINT_VERSION=1.7.7
NODE_MAJOR=20
# Kept in step with the runtime Dockerfile's uv pin so that an agent running
# `uv sync --frozen` locally resolves the same way CI does.
UV_VERSION=0.5
PYTHON_VERSION=3.12
